# Copy this file to .env and fill in real values.
# .env is ignored by git; this example file is safe to commit.

STEAM_API_KEY=your_steam_web_api_key_here
ADMIN_SECRET=choose-a-long-random-secret

# How long player achievement state is considered fresh during normal dashboard loads.
PLAYER_REFRESH_TTL_SECONDS=600

# Bind address. For deployment set HOST=0.0.0.0 to listen on all interfaces.
HOST=127.0.0.1
PORT=8765
